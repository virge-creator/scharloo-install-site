---
import Layout from '../layouts/Layout.astro';

const values = [
  {
    title: 'Kwaliteit',
    description: 'Wij werken uitsluitend met kwalitatieve materialen van gerenommeerde merken.',
    number: '01'
  },
  {
    title: 'Snelheid',
    description: 'De meeste installaties zijn binnen een dag gereed. Uw voertuig is snel weer inzetbaar.',
    number: '02'
  },
  {
    title: 'Service',
    description: 'Ook na de installatie staan wij voor u klaar. Bij vragen helpen wij u graag verder.',
    number: '03'
  },
];
---

<Layout title="Over ons" description="Leer meer over Scharloo-Install, uw specialist in telematica en voertuiginstallaties.">
  <!-- Hero -->
  <section class="min-h-[60vh] bg-black text-white flex items-end pb-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
      <p class="text-brand font-medium tracking-widest uppercase mb-4 animate-fade-in-up">Over ons</p>
      <h1 class="heading-xl animate-fade-in-up delay-100" style="opacity: 0;">
        Uw<br />
        <span class="text-gray-500">inbouwpartner</span>
      </h1>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-24 lg:py-32 bg-gray-950">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="reveal">
          <h2 class="text-4xl md:text-5xl font-bold mb-8">
            Vakmanschap<br />
            <span class="text-gray-500">& precisie</span>
          </h2>
        </div>
        <div class="reveal lg:pt-4">
          <div class="space-y-6 text-xl text-gray-400 leading-relaxed">
            <p>
              Scharloo-Install is gespecialiseerd in de professionele inbouw van 
              telematica en voertuigelektronica. Van ritregistratiesystemen tot 
              dashcams met live verbinding, van tachografen tot startblokkeringen.
            </p>
            <p>
              Onze kracht zit in precisie en oog voor detail. Elke installatie 
              wordt netjes en onzichtbaar weggewerkt, zonder losse kabels of 
              zichtbare aanpassingen.
            </p>
            <p>
              Wij werken voor zowel particulieren als bedrijven met wagenparken. 
              Of het nu gaat om één voertuig of een complete vloot — bij ons 
              bent u aan het juiste adres.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Big Statement -->
  <section class="py-24 lg:py-32 bg-black">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center reveal">
      <p class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight max-w-4xl mx-auto">
        "Elke installatie wordt netjes en 
        <span class="text-brand">onzichtbaar</span> weggewerkt"
      </p>
    </div>
  </section>

  <!-- Values -->
  <section class="py-24 lg:py-32 bg-gray-950">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="mb-16 reveal">
        <p class="text-brand font-medium tracking-widest uppercase mb-4">Onze waarden</p>
        <h2 class="text-4xl md:text-5xl font-bold">
          Waar wij<br />
          <span class="text-gray-500">voor staan</span>
        </h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-t border-l border-gray-800">
        {values.map(value => (
          <div class="p-8 lg:p-12 border-r border-b border-gray-800 reveal">
            <span class="text-6xl font-black text-gray-900">{value.number}</span>
            <h3 class="text-2xl font-bold -mt-6 mb-4">{value.title}</h3>
            <p class="text-gray-400 text-lg">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-24 bg-black">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center reveal">
        <div>
          <p class="text-6xl md:text-7xl font-black text-brand">500+</p>
          <p class="text-gray-500 mt-2 uppercase tracking-widest">Installaties</p>
        </div>
        <div>
          <p class="text-6xl md:text-7xl font-black text-brand">3000+</p>
          <p class="text-gray-500 mt-2 uppercase tracking-widest">Koffie gedronken</p>
        </div>
        <div>
          <p class="text-6xl md:text-7xl font-black text-brand">100%</p>
          <p class="text-gray-500 mt-2 uppercase tracking-widest">Vakmanschap</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-32 bg-brand text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center reveal">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-8">
        Laten we<br />samenwerken
      </h2>
      <a 
        href="/contact/" 
        class="group inline-flex items-center gap-3 bg-white text-brand rounded-full px-10 py-5 text-xl font-bold hover:bg-black hover:text-white transition-all duration-300"
      >
        Contact opnemen
        <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
      </a>
    </div>
  </section>
</Layout>

<script>
  const reveals = document.querySelectorAll('.reveal');
  
  const revealOnScroll = () => {
    reveals.forEach(el => {
      const top = el.getBoundingClientRect().top;
      if (top < window.innerHeight - 100) {
        el.classList.add('active');
      }
    });
  };
  
  window.addEventListener('scroll', revealOnScroll);
  revealOnScroll();
</script>
