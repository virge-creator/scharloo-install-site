---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Over ons" description="Leer meer over Scharloo-Install, uw specialist in voertuigelektronica.">
  <!-- Hero -->
  <section class="bg-black text-white py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <p class="text-brand font-medium mb-4 tracking-wide uppercase">Over ons</p>
      <h1 class="text-5xl md:text-6xl font-bold mb-6">Uw inbouwpartner</h1>
      <p class="text-xl text-gray-300 max-w-2xl">
        Al meer dan 15 jaar dé specialist in professionele voertuigelektronica installaties.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-black mb-6">
            Vakmanschap & precisie
          </h2>
          <div class="space-y-4 text-lg text-gray-600">
            <p>
              Scharloo-Install is gespecialiseerd in de professionele inbouw van 
              voertuigelektronica. Van ritregistratiesystemen tot dashcams, van 
              tachografen tot startblokkeringen – wij zorgen voor een vakkundige 
              installatie.
            </p>
            <p>
              Onze kracht zit in precisie en oog voor detail. Elke installatie 
              wordt netjes en onzichtbaar weggewerkt, zonder losse kabels of 
              zichtbare aanpassingen.
            </p>
            <p>
              Wij werken voor zowel particulieren als bedrijven met wagenparken. 
              Of het nu gaat om één voertuig of een complete vloot – bij ons bent 
              u aan het juiste adres.
            </p>
          </div>
        </div>
        <div class="bg-gray-100 aspect-square flex items-center justify-center">
          <span class="text-9xl opacity-20">🔧</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-black">Waar wij voor staan</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-8 border border-gray-200">
          <span class="text-4xl mb-4 block">✓</span>
          <h3 class="text-xl font-bold text-black mb-3">Kwaliteit</h3>
          <p class="text-gray-600">
            Wij werken uitsluitend met kwalitatieve materialen en apparatuur 
            van gerenommeerde merken.
          </p>
        </div>
        <div class="bg-white p-8 border border-gray-200">
          <span class="text-4xl mb-4 block">⚡</span>
          <h3 class="text-xl font-bold text-black mb-3">Snelheid</h3>
          <p class="text-gray-600">
            De meeste installaties zijn binnen een dag gereed. 
            Uw voertuig is snel weer inzetbaar.
          </p>
        </div>
        <div class="bg-white p-8 border border-gray-200">
          <span class="text-4xl mb-4 block">💬</span>
          <h3 class="text-xl font-bold text-black mb-3">Service</h3>
          <p class="text-gray-600">
            Ook na de installatie staan wij voor u klaar. 
            Bij vragen of problemen helpen wij u graag verder.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-black text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        Laten we samenwerken
      </h2>
      <p class="text-xl text-gray-300 mb-10 max-w-2xl mx-auto">
        Benieuwd wat wij voor u kunnen betekenen? Neem contact met ons op 
        voor een vrijblijvend gesprek.
      </p>
      <a 
        href="/contact" 
        class="inline-block bg-brand text-white px-10 py-4 text-lg font-medium hover:bg-brand-dark transition-colors"
      >
        Contact opnemen
      </a>
    </div>
  </section>
</Layout>
