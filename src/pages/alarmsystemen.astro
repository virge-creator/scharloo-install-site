---
import Layout from '../layouts/Layout.astro';

// Alarmsystemen — eenmalige prijs, incl. btw, montage en SCM/CCV-certificaat
const alarmPakketten = [
  {
    klasse: 'Klasse 2',
    prijs: '€749',
    handzender: '€799',
    populair: false,
    omschrijving: 'Startonderbreker met inbraak- en omtrekbeveiliging.',
    features: [
      'SCM/CCV-certificaat',
      'Startonderbreker',
      'Radardetectie en omtrekbeveiliging',
      'Noodstroomsirene',
    ],
  },
  {
    klasse: 'Klasse 3',
    prijs: '€899',
    handzender: '€949',
    populair: true,
    omschrijving: 'Klasse 2, uitgebreid met hellingshoekdetectie tegen wegslepen.',
    features: [
      'SCM/CCV-certificaat',
      'Startonderbreker',
      'Radardetectie en omtrekbeveiliging',
      'Hellingshoekdetectie',
      'Noodstroomsirene',
    ],
  },
];

// Voertuigvolgsystemen — eenmalige prijs + jaarlijks meldkamerabonnement (PAC)
const volgPakketten = [
  {
    klasse: 'Klasse 4',
    prijs: '€649',
    abonnement: '€275 per jaar',
    populair: false,
    omschrijving: 'Voertuigvolgsysteem met 24/7 meldkamer en jammingdetectie.',
    features: [
      'SCM/CCV-certificaat',
      'Voertuigvolgsysteem',
      'Startblokkade op afstand',
      '24/7 meldkamer',
      'Jammingdetectie',
    ],
  },
  {
    klasse: 'Klasse 5 — nieuwe installatie',
    prijs: '€1.495',
    abonnement: '€275 per jaar',
    populair: true,
    omschrijving: 'Het complete systeem: volgsysteem én alarm met pushmelding.',
    features: [
      'SCM/CCV-certificaat',
      'Voertuigvolgsysteem',
      'Startblokkade op afstand',
      '24/7 meldkamer',
      'Jammingdetectie',
      'Pushmelding bij alarm',
    ],
  },
  {
    klasse: 'Klasse 5 — bij bestaand klasse 3-alarm',
    prijs: '€725',
    abonnement: '€275 per jaar',
    populair: false,
    omschrijving: 'Heeft u al een klasse 3-alarm? Hiermee maakt u het compleet.',
    features: [
      'SCM/CCV-certificaat',
      'Voertuigvolgsysteem',
      'Startblokkade op afstand',
      '24/7 meldkamer',
      'Jammingdetectie',
      'Pushmelding bij alarm',
    ],
  },
  {
    klasse: 'Klasse TV — terugvindsysteem',
    prijs: '€299',
    abonnement: '€99 per jaar',
    populair: false,
    omschrijving: 'Compact terugvindsysteem om uw voertuig na diefstal te traceren.',
    features: [
      'SCM/CCV-certificaat',
      'Terugvindsysteem',
      '24/7 meldkamer',
    ],
  },
];
---

<Layout
  title="Alarmsystemen — prijzen en pakketten | Scharloo-Install"
  description="SCM/CCV-alarmsystemen en voertuigvolgsystemen voor uw voertuig, professioneel ingebouwd. Bekijk de pakketten en vanaf-prijzen, inclusief montage en SCM/CCV-certificaat."
>
  <!-- Hero -->
  <section class="min-h-[60vh] bg-black text-white flex items-end pb-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
      <p class="text-brand font-medium tracking-widest uppercase mb-4 animate-fade-in-up">Beveiliging</p>
      <h1 class="heading-xl animate-fade-in-up delay-100" style="opacity: 0;">
        Alarmsystemen die<br />
        <span class="text-gray-500">uw voertuig beschermen</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mt-8 animate-fade-in-up delay-200" style="opacity: 0;">
        SCM/CCV-goedgekeurd en professioneel ingebouwd — op locatie of in de werkplaats. Hieronder vindt u onze pakketten en vanaf-prijzen.
      </p>
    </div>
  </section>

  <!-- Welke klasse -->
  <section class="py-24 bg-gray-950">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl reveal">
        <p class="text-brand font-medium tracking-widest uppercase mb-4">Welke klasse heeft u nodig?</p>
        <p class="text-xl text-gray-400 leading-relaxed">
          Voertuigbeveiliging is door <span class="text-white font-semibold">SCM/CCV</span> ingedeeld in klassen, van een alarm met inbraak- en omtrekbeveiliging tot een volledig gekoppeld volgsysteem met 24/7 meldkamer. Welke klasse voor u verplicht of verstandig is, hangt af van uw voertuig en de eisen van uw verzekeraar. Weet u het niet zeker? <span class="text-white font-semibold">Wij adviseren u vrijblijvend.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Alarmsystemen -->
  <section class="py-24 bg-black">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal">
        <p class="text-brand font-medium tracking-widest uppercase mb-4">Alarmsystemen</p>
        <h2 class="heading-lg mb-4">
          Inbraak- en<br />
          <span class="text-gray-500">wegsleepbeveiliging</span>
        </h2>
        <p class="text-xl text-gray-400 mb-12 max-w-2xl">
          Eenmalige prijs, inclusief btw, montage en SCM/CCV-certificaat.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {alarmPakketten.map((pakket) => (
          <div class={`reveal relative bg-gray-950 p-8 border ${pakket.populair ? 'border-brand' : 'border-gray-800'} hover:border-brand transition-colors flex flex-col`}>
            {pakket.populair && (
              <span class="absolute -top-3 left-8 bg-brand text-white text-xs font-bold uppercase tracking-wide px-3 py-1">Meest gekozen</span>
            )}
            <h3 class="text-2xl font-bold mb-2">{pakket.klasse}</h3>
            <p class="text-gray-400 mb-6">{pakket.omschrijving}</p>
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-gray-500 text-sm">vanaf</span>
              <span class="text-4xl font-black text-white">{pakket.prijs}</span>
            </div>
            <p class="text-gray-500 text-sm mb-6">Met losse handzender: {pakket.handzender}</p>
            <ul class="space-y-3 mb-8">
              {pakket.features.map((feature) => (
                <li class="flex items-center gap-3 text-gray-300">
                  <span class="w-2 h-2 bg-brand flex-shrink-0"></span>
                  {feature}
                </li>
              ))}
            </ul>
            <a href="#contact" class="mt-auto inline-flex items-center justify-center gap-2 border border-gray-700 text-white rounded-full px-6 py-3 font-semibold hover:border-brand hover:text-brand transition-colors">
              Offerte aanvragen
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Voertuigvolgsystemen -->
  <section class="py-24 bg-gray-950">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal">
        <p class="text-brand font-medium tracking-widest uppercase mb-4">Voertuigvolgsystemen</p>
        <h2 class="heading-lg mb-4">
          Volgen en<br />
          <span class="text-gray-500">terugvinden</span>
        </h2>
        <p class="text-xl text-gray-400 mb-12 max-w-2xl">
          Eenmalige prijs plus een jaarlijks abonnement op de meldkamer (PAC).
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        {volgPakketten.map((pakket) => (
          <div class={`reveal relative bg-black p-8 border ${pakket.populair ? 'border-brand' : 'border-gray-800'} hover:border-brand transition-colors flex flex-col`}>
            {pakket.populair && (
              <span class="absolute -top-3 left-8 bg-brand text-white text-xs font-bold uppercase tracking-wide px-3 py-1">Compleet</span>
            )}
            <h3 class="text-xl font-bold mb-2">{pakket.klasse}</h3>
            <p class="text-gray-400 mb-6 text-sm">{pakket.omschrijving}</p>
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-gray-500 text-sm">vanaf</span>
              <span class="text-3xl font-black text-white">{pakket.prijs}</span>
            </div>
            <p class="text-gray-500 text-sm mb-6">+ {pakket.abonnement}</p>
            <ul class="space-y-3 mb-8">
              {pakket.features.map((feature) => (
                <li class="flex items-center gap-3 text-gray-300 text-sm">
                  <span class="w-2 h-2 bg-brand flex-shrink-0"></span>
                  {feature}
                </li>
              ))}
            </ul>
            <a href="#contact" class="mt-auto inline-flex items-center justify-center gap-2 border border-gray-700 text-white rounded-full px-6 py-3 font-semibold hover:border-brand hover:text-brand transition-colors">
              Offerte aanvragen
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Goed om te weten -->
  <section class="py-24 bg-black">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl reveal">
        <p class="text-brand font-medium tracking-widest uppercase mb-4">Goed om te weten</p>
        <ul class="space-y-4">
          <li class="flex items-start gap-4 text-xl text-gray-300">
            <span class="text-brand text-2xl leading-none">✓</span>
            Alle prijzen zijn inclusief btw, montage en SCM/CCV-certificaat.
          </li>
          <li class="flex items-start gap-4 text-xl text-gray-300">
            <span class="text-brand text-2xl leading-none">✓</span>
            Het zijn vanaf-prijzen. De definitieve prijs hangt af van merk, model en bouwjaar — bijvoorbeeld bij een dubbele startblokkering of wanneer er LED-verlichting moet worden aangestuurd.
          </li>
          <li class="flex items-start gap-4 text-xl text-gray-300">
            <span class="text-brand text-2xl leading-none">✓</span>
            Het jaarbedrag bij de volgsystemen is het abonnement op de particuliere alarmcentrale (PAC), die uw voertuig 24/7 in de gaten houdt.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="py-32 bg-brand text-white scroll-mt-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center reveal">
      <h2 class="heading-lg mb-8">
        Benieuwd wat het<br />voor uw voertuig kost?
      </h2>
      <p class="text-xl text-white/80 mb-12 max-w-xl mx-auto">
        Stuur ons het merk, type, bouwjaar en kenteken, dan maken wij een passend voorstel. We zijn inzetbaar door heel Nederland.
      </p>
      <a
        href="/contact/"
        class="group inline-flex items-center gap-3 bg-white text-brand rounded-full px-10 py-5 text-xl font-bold hover:bg-black hover:text-white transition-all duration-300"
      >
        Vraag een offerte aan
        <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
      </a>
      <div class="mt-12 text-white/80">
        <p class="text-lg"><a href="tel:+31182796197" class="hover:text-white transition-colors">📞 (0182) 79 61 97</a></p>
        <p class="text-lg"><a href="mailto:info@scharloo-install.nl" class="hover:text-white transition-colors">✉ info@scharloo-install.nl</a></p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const reveals = document.querySelectorAll('.reveal');

  const revealOnScroll = () => {
    reveals.forEach(el => {
      const top = el.getBoundingClientRect().top;
      if (top < window.innerHeight - 100) {
        el.classList.add('active');
      }
    });
  };

  window.addEventListener('scroll', revealOnScroll);
  revealOnScroll();
</script>
