---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    name: 'Julian Scharloo',
    role: 'Founder / CEO',
    image: '/images/team/julian.jpg',
    description: 'Julian is een belangrijke kracht achter de sfeer binnen Scharloo-Install en vindt een hecht team minstens zo belangrijk als goed werk leveren. Hij zorgt voor verbinding binnen het bedrijf en gelooft dat sterke teambuilding de basis is voor kwaliteit, inzet en een prettige samenwerking.',
    accent: true,
  },
  {
    name: 'Coen',
    role: 'Inbouw Specialist',
    image: '/images/team/coen.jpg',
    description: 'Altijd present op de vrijdagmiddagborrel, liefhebber van een goed biertje en vaste klant bij de visboer — helemaal in de sfeer van Scharloo-Install: gezellig, recht door zee en altijd gericht op kwaliteit en een verzorgde inbouw.',
    accent: false,
  },
  {
    name: 'Kane',
    role: 'Inbouw Specialist',
    image: '/images/team/kane.jpg',
    description: 'Een echte autoliefhebber pur sang, met oog voor detail en kwaliteit zoals je dat bij Scharloo-Install mag verwachten — en bij Kane? Daar zit het altijd snor.',
    accent: false,
  },
];
---

<Layout title="Ons Team" description="Maak kennis met het team van Scharloo-Install B.V. — vakmanschap, kwaliteit en een persoonlijke aanpak.">
  <!-- Hero -->
  <section class="min-h-[60vh] bg-black text-white flex items-end pb-20 relative overflow-hidden">
    <!-- Decorative dots -->
    <div class="absolute top-0 right-0 w-[300px] h-[300px] opacity-30" style="background-image: radial-gradient(circle, rgba(0,153,255,0.15) 2px, transparent 2px); background-size: 18px 18px; mask-image: radial-gradient(ellipse at top right, black 0%, transparent 70%); -webkit-mask-image: radial-gradient(ellipse at top right, black 0%, transparent 70%);"></div>
    
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
      <p class="text-brand font-medium tracking-widest uppercase mb-4 animate-fade-in-up">Ons team</p>
      <h1 class="heading-xl animate-fade-in-up delay-100" style="opacity: 0;">
        De mensen<br />
        <span class="text-gray-500">achter de inbouw</span>
      </h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-24 lg:py-32 bg-gray-950">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="reveal">
          <h2 class="text-4xl md:text-5xl font-bold mb-8">
            Maak kennis<br />
            <span class="text-gray-500">met ons team</span>
          </h2>
        </div>
        <div class="reveal lg:pt-4">
          <div class="space-y-6 text-xl text-gray-400 leading-relaxed">
            <p>
              Bij Scharloo-Install B.V. staat ons team klaar om professionele 
              voertuiginstallaties te verzorgen met oog voor kwaliteit, 
              klanttevredenheid en flexibiliteit.
            </p>
            <p>
              Ons team combineert ervaring, kennis en een persoonlijke aanpak 
              om elke installatie perfect te realiseren.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Members -->
  <section class="bg-black">
    {team.map((member, index) => (
      <div class={`py-24 lg:py-32 ${index % 2 === 0 ? 'bg-black' : 'bg-gray-950'} relative overflow-hidden`}>
        {/* Subtle dot accent on alternating sides */}
        {index % 2 === 0 ? (
          <div class="absolute bottom-0 right-0 w-[250px] h-[250px]" style="background-image: radial-gradient(circle, rgba(0,153,255,0.08) 2px, transparent 2px); background-size: 18px 18px; mask-image: radial-gradient(ellipse at bottom right, black 0%, transparent 70%); -webkit-mask-image: radial-gradient(ellipse at bottom right, black 0%, transparent 70%); pointer-events: none;"></div>
        ) : (
          <div class="absolute top-0 left-0 w-[200px] h-[200px]" style="background-image: radial-gradient(circle, rgba(0,153,255,0.06) 2px, transparent 2px); background-size: 18px 18px; mask-image: radial-gradient(ellipse at top left, black 0%, transparent 70%); -webkit-mask-image: radial-gradient(ellipse at top left, black 0%, transparent 70%); pointer-events: none;"></div>
        )}
        
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center ${index % 2 !== 0 ? 'lg:direction-rtl' : ''}`}>
            {/* Photo */}
            <div class={`reveal ${index % 2 !== 0 ? 'lg:order-2' : ''}`}>
              <div class="photo-card aspect-[4/5] max-w-md mx-auto lg:mx-0 relative group">
                <img 
                  src={member.image} 
                  alt={`Foto van ${member.name}`}
                  class="w-full h-full object-cover"
                  onerror="this.style.display='none'; this.parentElement.classList.add('bg-gray-900', 'flex', 'items-center', 'justify-center'); this.parentElement.innerHTML='<span class=\\'text-6xl\\'>👤</span>'"
                />
                {/* Brand accent line */}
                <div class="absolute bottom-0 left-0 w-0 h-1 bg-gradient-to-r from-brand to-brand-light group-hover:w-full transition-all duration-500 z-10"></div>
              </div>
            </div>
            
            {/* Info */}
            <div class={`reveal ${index % 2 !== 0 ? 'lg:order-1' : ''}`}>
              {/* Role badge */}
              <div class="inline-flex items-center gap-2 mb-6">
                <span class="w-8 h-[2px] bg-brand"></span>
                <span class="text-brand font-medium tracking-widest uppercase text-sm">{member.role}</span>
              </div>
              
              <h3 class="text-4xl md:text-5xl font-bold mb-6">{member.name}</h3>
              
              <p class="text-xl text-gray-400 leading-relaxed max-w-lg">
                {member.description}
              </p>
              
              {member.accent && (
                <div class="mt-10 p-6 border border-gray-800 bg-gray-950/50 relative">
                  <div class="absolute top-0 left-0 w-1 h-full bg-brand"></div>
                  <p class="text-gray-500 italic text-lg pl-4">
                    "Sterke teambuilding is de basis voor kwaliteit"
                  </p>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    ))}
  </section>

  <!-- Team Spirit Statement -->
  <section class="py-24 lg:py-32 bg-black">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center reveal">
      <p class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight max-w-4xl mx-auto">
        Vakmanschap met een 
        <span class="text-brand">persoonlijke</span> touch
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-32 bg-brand text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center reveal">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-8">
        Kennismaken?
      </h2>
      <p class="text-xl opacity-80 mb-10 max-w-2xl mx-auto">
        Benieuwd wat ons team voor u kan betekenen? Neem vrijblijvend contact op.
      </p>
      <a 
        href="/contact/" 
        class="group inline-flex items-center gap-3 bg-white text-brand px-10 py-5 text-xl font-bold hover:bg-black hover:text-white transition-all duration-300"
      >
        Contact opnemen
        <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
      </a>
    </div>
  </section>
</Layout>

<script>
  const reveals = document.querySelectorAll('.reveal');
  
  const revealOnScroll = () => {
    reveals.forEach(el => {
      const top = el.getBoundingClientRect().top;
      if (top < window.innerHeight - 100) {
        el.classList.add('active');
      }
    });
  };
  
  window.addEventListener('scroll', revealOnScroll);
  revealOnScroll();
</script>
