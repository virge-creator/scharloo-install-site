---
import Layout from '../layouts/Layout.astro';

const mainServices = [
  {
    id: 'voertuigvolgsystemen',
    title: 'Voertuigvolgsystemen',
    subtitle: 'Tracking & ritregistratie',
    description: 'Installatie van systemen voor realtime tracking en ritregistratie. Perfect voor wagenparkbeheer en fiscale doeleinden.',
    features: ['GPS tracking', 'Realtime locatie', 'Ritregistratie', 'Online dashboard'],
    number: '01'
  },
  {
    id: 'dashcams',
    title: 'Dashcams',
    subtitle: 'Veiligheid & bewijslast',
    description: 'Installatie van dashcams voor veiligheid en bewijslast. Professionele, onzichtbare inbouw zonder losse kabels.',
    features: ['Live verbinding', 'Onzichtbare installatie', 'Voor- en achtercamera', 'Parkeermodus'],
    number: '02',
    link: { text: 'Dashcam webshop', url: 'https://scharloo-install.vercel.app/nl', isButton: true }
  },
  {
    id: 'alarmsystemen',
    title: 'Alarmsystemen',
    subtitle: 'SCM gecertificeerd',
    description: 'Installatie van alarmklasse 1 t/m 5 systemen. SCM gecertificeerd voor optimale beveiliging van uw voertuig.',
    features: ['Klasse 1 t/m 5', 'SCM gecertificeerd', 'Verzekeraar goedgekeurd', 'Anti-diefstal'],
    number: '03'
  },
];

const extensions = [
  {
    id: 'tachosystemen',
    title: 'Tachosystemen',
    subtitle: 'Remote download',
    description: 'Installatie van GPS systeem met Remote tacho download integratie. Voldoe aan de wettelijke eisen zonder handmatige uitlezing.',
    features: ['Remote download', 'Conform wetgeving', 'Digitale tachograaf', 'Automatisch uitlezen'],
    number: '04'
  },
  {
    id: 'canbus',
    title: 'CAN-bus koppelingen',
    subtitle: 'Voertuiggegevens',
    description: 'Installatie van voertuigvolgsysteem met CAN-bus koppeling waarbij voertuiggegevens op afstand ingezien kunnen worden.',
    features: ['Brandstofverbruik', 'Rijstijlanalyse', 'Foutcodes uitlezen', 'Alle merken'],
    number: '05'
  },
  {
    id: 'driverid',
    title: 'Driver ID / RFID',
    subtitle: 'Identificatie',
    description: 'Installatie voor identificatie van bestuurders. Weet altijd wie er rijdt en koppel ritten automatisch aan de juiste persoon.',
    features: ['RFID tags/kaarten', 'Automatische herkenning', 'Ritregistratie koppeling', 'Meerdere bestuurders'],
    number: '06'
  },
  {
    id: 'io',
    title: 'I/O integraties',
    subtitle: 'Maatwerk koppelingen',
    description: 'Installatie van maatwerk koppelingen en extra functionaliteiten. Van sensoren tot schakelaars, alles is mogelijk.',
    features: ['Maatwerk', 'Sensoren', 'Schakelaars', 'Systeemintegratie'],
    number: '07'
  },
];

const reasons = [
  'Specialist in installatie van voertuigsystemen',
  'Focus op kwaliteit en klanttevredenheid',
  'Flexibel en snel inzetbaar',
  'Ervaring met diverse systemen en merken',
  'Actief in Nederland en België',
];
---

<Layout title="Installatie voertuigvolgsystemen & alarmsystemen | Scharloo-Install" description="Professionele installatie van voertuigvolgsystemen, dashcams en SCM alarmsystemen. Uitbreidingen zoals CAN-bus, tacho en RFID mogelijk. Actief in Nederland en België.">
  <!-- Hero -->
  <section class="min-h-[60vh] bg-black text-white flex items-end pb-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
      <p class="text-brand font-medium tracking-widest uppercase mb-4 animate-fade-in-up">Onze diensten</p>
      <h1 class="heading-xl animate-fade-in-up delay-100" style="opacity: 0;">
        Inbouw<br />
        <span class="text-gray-500">voertuigsystemen</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mt-8 animate-fade-in-up delay-200" style="opacity: 0;">
        Scharloo-Install B.V. is specialist in de installatie van voertuigsystemen. Wij verzorgen professionele inbouw voor bedrijven en wagenparken, met focus op kwaliteit en klanttevredenheid.
      </p>
    </div>
  </section>

  <!-- Main Services -->
  <section class="bg-gray-950 py-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <p class="text-brand font-medium tracking-widest uppercase mb-4 reveal">Hoofddiensten</p>
    </div>
  </section>

  <section class="bg-black">
    {mainServices.map((service, index) => (
      <div 
        id={service.id} 
        class={`scroll-mt-24 border-b border-gray-800 ${index % 2 === 1 ? 'bg-gray-950' : 'bg-black'}`}
      >
        <div class="max-w-7xl mx-auto px-6 lg:px-8 py-24 lg:py-32">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
            <!-- Left: Title and number -->
            <div class="reveal">
              <span class="text-7xl lg:text-8xl font-black text-gray-900">{service.number}</span>
              <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold -mt-8 lg:-mt-10">
                {service.title}<br />
                <span class="text-gray-500">{service.subtitle}</span>
              </h2>
            </div>
            
            <!-- Right: Description and features -->
            <div class="reveal lg:pt-16">
              <p class="text-xl text-gray-400 mb-8 leading-relaxed">
                {service.description}
              </p>
              <ul class="grid grid-cols-2 gap-4 mb-6">
                {service.features.map(feature => (
                  <li class="flex items-center gap-3 text-gray-300">
                    <span class="w-2 h-2 bg-brand flex-shrink-0"></span>
                    {feature}
                  </li>
                ))}
              </ul>
              {service.link && (
                <a 
                  href={service.link.url} 
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-3 bg-brand text-white rounded-full px-6 py-3 font-semibold hover:bg-white hover:text-black transition-all duration-300"
                >
                  {service.link.text}
                  <span>→</span>
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    ))}
  </section>

  <!-- Extensions Section -->
  <section class="bg-gray-950 py-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <p class="text-brand font-medium tracking-widest uppercase mb-4 reveal">Uitbreidingen & integraties</p>
      <p class="text-xl text-gray-400 reveal">
        Deze opties worden gekoppeld aan voertuigvolgsystemen voor extra functionaliteit.
      </p>
    </div>
  </section>

  <section class="bg-black">
    {extensions.map((service, index) => (
      <div 
        id={service.id} 
        class={`scroll-mt-24 border-b border-gray-800 ${index % 2 === 1 ? 'bg-gray-950' : 'bg-black'}`}
      >
        <div class="max-w-7xl mx-auto px-6 lg:px-8 py-24 lg:py-32">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
            <!-- Left: Title and number -->
            <div class="reveal">
              <span class="text-7xl lg:text-8xl font-black text-gray-900">{service.number}</span>
              <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold -mt-8 lg:-mt-10">
                {service.title}<br />
                <span class="text-gray-500">{service.subtitle}</span>
              </h2>
            </div>
            
            <!-- Right: Description and features -->
            <div class="reveal lg:pt-16">
              <p class="text-xl text-gray-400 mb-8 leading-relaxed">
                {service.description}
              </p>
              <ul class="grid grid-cols-2 gap-4">
                {service.features.map(feature => (
                  <li class="flex items-center gap-3 text-gray-300">
                    <span class="w-2 h-2 bg-brand flex-shrink-0"></span>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    ))}
  </section>

  <!-- Why Scharloo-Install -->
  <section class="py-24 bg-gray-950">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl reveal">
        <p class="text-brand font-medium tracking-widest uppercase mb-4">Waarom Scharloo-Install</p>
        <ul class="space-y-4">
          {reasons.map(reason => (
            <li class="flex items-center gap-4 text-xl text-gray-300">
              <span class="text-brand text-2xl">✓</span>
              {reason}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-32 bg-brand text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center reveal">
      <h2 class="heading-lg mb-8">
        Op zoek naar een<br />betrouwbare installatiepartner?
      </h2>
      <p class="text-xl text-white/80 mb-12 max-w-xl mx-auto">
        Neem contact op of stel je vragen direct
      </p>
      <a 
        href="/contact/" 
        class="group inline-flex items-center gap-3 bg-white text-brand rounded-full px-10 py-5 text-xl font-bold hover:bg-black hover:text-white transition-all duration-300"
      >
        Contact opnemen
        <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
      </a>
      <div class="mt-12 text-white/80">
        <p class="text-lg"><a href="tel:+31182796197" class="hover:text-white transition-colors">📞 (0182) 79 61 97</a></p>
        <p class="text-lg"><a href="mailto:info@scharloo-install.nl" class="hover:text-white transition-colors">✉ info@scharloo-install.nl</a></p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const reveals = document.querySelectorAll('.reveal');
  
  const revealOnScroll = () => {
    reveals.forEach(el => {
      const top = el.getBoundingClientRect().top;
      if (top < window.innerHeight - 100) {
        el.classList.add('active');
      }
    });
  };
  
  window.addEventListener('scroll', revealOnScroll);
  revealOnScroll();
</script>
