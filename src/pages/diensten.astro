---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'ritregistratie',
    title: 'Ritregistratie Systemen',
    description: 'Automatische en nauwkeurige registratie van al uw ritten. Perfect voor fiscale doeleinden, wagenparkbeheer en inzicht in rijgedrag. Onze systemen zijn goedgekeurd door de Belastingdienst.',
    features: ['GPS tracking', 'Automatische ritherkenning', 'Fiscaal goedgekeurd', 'Online dashboard'],
    icon: '📍'
  },
  {
    id: 'dashcams',
    title: 'Dashcam Inbouw',
    description: 'Professionele, onzichtbare inbouw van dashcams. Geen losse kabels, geen zuignappen. Uw dashcam wordt netjes weggewerkt met een permanente stroomvoorziening.',
    features: ['Onzichtbare installatie', 'Voor- en achtercamera', 'Parkeermodus', 'Loop recording'],
    icon: '📹'
  },
  {
    id: 'canbus',
    title: 'CAN Bus Installatie',
    description: 'Deskundige aansluiting op het CAN Bus systeem van uw voertuig. Wij zorgen voor een veilige integratie zonder schade aan de elektronica van uw auto.',
    features: ['Veilige integratie', 'Geen beschadiging', 'Alle merken', 'Diagnose mogelijkheid'],
    icon: '🔌'
  },
  {
    id: 'driverid',
    title: 'Driver ID / RFID',
    description: 'Identificatiesystemen voor bestuurders met RFID technologie. Weet altijd wie er rijdt en koppel ritten automatisch aan de juiste bestuurder.',
    features: ['RFID tags/kaarten', 'Automatische herkenning', 'Koppeling met ritregistratie', 'Meerdere bestuurders'],
    icon: '🪪'
  },
  {
    id: 'tachograaf',
    title: 'Tachografen',
    description: 'Installatie, kalibratie en onderhoud van digitale tachografen. Wij zorgen dat u voldoet aan alle wettelijke eisen voor rij- en rusttijden.',
    features: ['Digitale tachograaf', 'Kalibratie', '2-jaarlijkse keuring', 'Wettelijk conform'],
    icon: '⏱️'
  },
  {
    id: 'startblokkering',
    title: 'Startblokkeringen',
    description: 'Bescherm uw voertuig tegen diefstal met een professioneel startblokkeringssysteem. Extra zekerheid naast uw standaard beveiliging.',
    features: ['Anti-diefstal', 'RFID of PIN', 'SCM gecertificeerd', 'Verzekeraar goedgekeurd'],
    icon: '🔒'
  },
  {
    id: 'io',
    title: 'I/O Installaties',
    description: 'Maatwerkoplossingen voor input/output installaties. Van sensoren tot schakelaars, wij realiseren uw specifieke wensen.',
    features: ['Maatwerk', 'Sensoren', 'Schakelaars', 'Integratie bestaande systemen'],
    icon: '⚡'
  },
];
---

<Layout title="Diensten" description="Onze diensten: ritregistratie, dashcams, CAN bus, tachografen, startblokkeringen en meer.">
  <!-- Hero -->
  <section class="bg-black text-white py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <p class="text-brand font-medium mb-4 tracking-wide uppercase">Wat wij doen</p>
      <h1 class="text-5xl md:text-6xl font-bold mb-6">Onze diensten</h1>
      <p class="text-xl text-gray-300 max-w-2xl">
        Van ritregistratie tot startblokkeringen. Wij zijn uw specialist voor 
        professionele voertuigelektronica installaties.
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="space-y-24">
        {services.map((service, index) => (
          <div id={service.id} class="scroll-mt-24">
            <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
              <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
                <span class="text-6xl mb-6 block">{service.icon}</span>
                <h2 class="text-3xl md:text-4xl font-bold text-black mb-4">{service.title}</h2>
                <p class="text-lg text-gray-600 mb-8">{service.description}</p>
                <ul class="grid grid-cols-2 gap-4">
                  {service.features.map(feature => (
                    <li class="flex items-center text-gray-700">
                      <span class="w-2 h-2 bg-brand mr-3"></span>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
              <div class={`bg-gray-100 aspect-video flex items-center justify-center ${index % 2 === 1 ? 'lg:order-1' : ''}`}>
                <span class="text-8xl opacity-20">{service.icon}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-brand text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        Interesse in onze diensten?
      </h2>
      <p class="text-xl text-white/80 mb-10 max-w-2xl mx-auto">
        Vraag vrijblijvend een offerte aan of neem contact op voor meer informatie.
      </p>
      <a 
        href="/contact" 
        class="inline-block bg-white text-brand px-10 py-4 text-lg font-medium hover:bg-gray-100 transition-colors"
      >
        Contact opnemen
      </a>
    </div>
  </section>
</Layout>
