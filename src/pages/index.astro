---
import Layout from '../layouts/Layout.astro';

const services = [
  { title: 'Voertuigvolgsystemen', id: 'voertuigvolgsystemen' },
  { title: 'Tachosystemen', id: 'tachosystemen' },
  { title: 'Dashcams', id: 'dashcams' },
  { title: 'Startblokkeringen', id: 'startblokkeringen' },
  { title: 'CAN-bus koppelingen', id: 'canbus' },
  { title: 'Driver ID / RFID', id: 'driverid' },
  { title: 'I/O integraties', id: 'io' },
];

const partners = [
  'FleetComplete', 'Webfleet', 'TrackJack', 'ULU/Cartracker', 
  'Linqo', 'Global TrackMarks', 'GPS-Buddy', 'Allsetra', 'Suivo'
];

const reasons = [
  'Gespecialiseerd in voertuigsystemen',
  'Nette en professionele afwerking',
  'Flexibel inzetbaar',
  'Ervaring met diverse merken en systemen',
  'Actief in Nederland en België',
];
---

<Layout title="Scharloo-Install B.V. | Inbouw voertuigsystemen" description="Specialist in het installeren van voertuigvolgsystemen, tacho, dashcams, CAN-bus en startblokkeringen. Actief in Nederland en België.">
  <!-- Hero Section -->
  <section class="min-h-screen bg-black text-white flex flex-col justify-center relative overflow-hidden">
    
    <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-20">
      <div class="space-y-8">
        <!-- Tagline -->
        <p class="text-brand font-medium tracking-widest uppercase animate-fade-in-up">
          Professionele inbouw
        </p>
        
        <!-- Main heading -->
        <h1 class="heading-xl animate-fade-in-up delay-100" style="opacity: 0;">
          Specialist in<br />
          <span class="text-brand">voertuig</span>systemen
        </h1>
        
        <!-- Subtext -->
        <p class="text-xl md:text-2xl text-gray-400 max-w-2xl animate-fade-in-up delay-200" style="opacity: 0;">
          Inbouw van voertuigvolgsystemen, tachosystemen, dashcams, CAN-bus koppelingen en startblokkeringen. Actief in Nederland en België. Kwaliteit, nette afwerking en snel schakelen.
        </p>
        
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-8 animate-fade-in-up delay-300" style="opacity: 0;">
          <a 
            href="/scharloo-install-site/contact/" 
            class="group bg-brand text-white px-8 py-4 text-lg font-semibold hover:bg-white hover:text-black transition-all duration-300 inline-flex items-center justify-center gap-3"
          >
            Offerte aanvragen
            <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
          </a>
          <a 
            href="/scharloo-install-site/contact/" 
            class="border-2 border-white text-white px-8 py-4 text-lg font-semibold hover:bg-white hover:text-black transition-all duration-300 text-center"
          >
            Contact opnemen
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Partner ticker -->
  <section class="bg-brand text-white py-4 overflow-hidden">
    <div class="animate-marquee whitespace-nowrap flex">
      {[...Array(2)].map(() => (
        <div class="flex items-center">
          {partners.map(partner => (
            <span class="mx-8 text-lg font-medium flex items-center gap-4">
              <span class="w-2 h-2 bg-white rounded-full"></span>
              <span>{partner}</span>
            </span>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-24 bg-gray-950">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl reveal">
        <p class="text-brand font-medium tracking-widest uppercase mb-4">Over ons</p>
        <h2 class="heading-lg mb-8">
          Uw partner voor<br />
          <span class="text-gray-500">professionele inbouw</span>
        </h2>
        <p class="text-xl text-gray-400 leading-relaxed">
          Scharloo-Install B.V. is dé partner voor professionele inbouw van telematica- en voertuigsystemen. Wij werken voor zakelijke klanten die zoeken naar een betrouwbare installateur met oog voor kwaliteit en een nette oplevering.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-32 bg-black">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Section header with video -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 mb-20 items-center">
        <div class="reveal">
          <p class="text-brand font-medium tracking-widest uppercase mb-4">Diensten</p>
          <h2 class="heading-lg">
            Onze<br />
            <span class="text-gray-500">diensten</span>
          </h2>
        </div>
        <!-- YouTube Short (Portrait) -->
        <div class="reveal flex justify-center lg:justify-end">
          <div class="video-card">
            <iframe 
              src="https://www.youtube.com/embed/Vykfc3ZDeMw" 
              title="Scharloo-Install video"
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>
      
      <!-- Services list -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border-t border-gray-800 reveal">
        {services.map((service, i) => (
          <a 
            href={`/scharloo-install-site/diensten/#${service.id}`}
            class={`group py-8 md:py-12 border-b border-gray-800 flex items-center justify-between hover:bg-gray-900 transition-colors px-4 md:px-8 ${i % 2 === 0 ? 'md:border-r' : ''}`}
          >
            <span class="text-2xl md:text-3xl font-bold group-hover:text-brand transition-colors">
              {service.title}
            </span>
            <span class="text-3xl text-gray-600 group-hover:text-brand group-hover:translate-x-2 transition-all duration-300">
              →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-32 bg-gray-950">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <p class="text-brand font-medium tracking-widest uppercase mb-4">Waarom wij</p>
          <h2 class="heading-lg mb-8">
            Waarom kiezen<br />
            <span class="text-gray-500">voor ons</span>
          </h2>
          <ul class="space-y-4">
            {reasons.map(reason => (
              <li class="flex items-center gap-4 text-xl text-gray-300">
                <span class="text-brand text-2xl">✓</span>
                {reason}
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal photo-card photo-card-accent">
          <img 
            src="/scharloo-install-site/images/team.jpg" 
            alt="Het Scharloo-Install team" 
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Trusted By -->
  <section class="py-24 bg-black">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center reveal">
      <p class="text-brand font-medium tracking-widest uppercase mb-8">Trusted by</p>
      <p class="text-xl text-gray-400 max-w-3xl mx-auto">
        Ervaring met installaties voor onder andere <span class="text-white font-semibold">FleetComplete</span>, <span class="text-white font-semibold">Webfleet</span>, <span class="text-white font-semibold">TrackJack</span>, <span class="text-white font-semibold">ULU/Cartracker</span>, <span class="text-white font-semibold">Linqo</span>, <span class="text-white font-semibold">Global TrackMarks</span>, <span class="text-white font-semibold">GPS-Buddy</span> en <span class="text-white font-semibold">Allsetra</span>.
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-32 bg-brand text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center reveal">
      <h2 class="heading-lg mb-8">
        Op zoek naar een<br />betrouwbare partner?
      </h2>
      <p class="text-xl text-white/80 mb-12 max-w-xl mx-auto">
        Neem contact met ons op voor de mogelijkheden of vraag direct een offerte aan.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/scharloo-install-site/contact/" 
          class="group inline-flex items-center gap-3 bg-white text-brand px-10 py-5 text-xl font-bold hover:bg-black hover:text-white transition-all duration-300"
        >
          Contact opnemen
          <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
        </a>
      </div>
      <div class="mt-12 text-white/80">
        <p class="text-lg">📞 (0182) 79 61 97</p>
        <p class="text-lg">✉ info@scharloo-install.nl</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Scroll reveal animation
  const reveals = document.querySelectorAll('.reveal');
  
  const revealOnScroll = () => {
    reveals.forEach(el => {
      const top = el.getBoundingClientRect().top;
      const windowHeight = window.innerHeight;
      
      if (top < windowHeight - 100) {
        el.classList.add('active');
      }
    });
  };
  
  window.addEventListener('scroll', revealOnScroll);
  revealOnScroll();
</script>
