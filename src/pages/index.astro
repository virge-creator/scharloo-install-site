---
import Layout from '../layouts/Layout.astro';

const services = [
  { title: 'Ritregistratie', id: 'ritregistratie' },
  { title: 'Dashcams', id: 'dashcams' },
  { title: 'CAN Bus', id: 'canbus' },
  { title: 'Driver ID', id: 'driverid' },
  { title: 'Tachografen', id: 'tachograaf' },
  { title: 'Startblokkeringen', id: 'startblokkering' },
  { title: 'I/O Installaties', id: 'io' },
];

const projects = [
  { title: 'Ritregistratie systemen', category: 'Telematica' },
  { title: 'Dashcam met live verbinding', category: 'Veiligheid' },
  { title: 'CAN Bus installatie', category: 'Elektronica' },
  { title: 'Tachograaf kalibratie', category: 'Wetgeving' },
  { title: 'RFID startblokkering', category: 'Beveiliging' },
];
---

<Layout title="Home">
  <!-- Hero Section - Full viewport, bold -->
  <section class="min-h-screen bg-black text-white flex flex-col justify-center relative overflow-hidden">
    
    <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-20">
      <div class="space-y-8">
        <!-- Tagline -->
        <p class="text-brand font-medium tracking-widest uppercase animate-fade-in-up">
          Uw inbouwpartner
        </p>
        
        <!-- Main heading - HUGE -->
        <h1 class="heading-xl animate-fade-in-up delay-100" style="opacity: 0;">
          Specialist in<br />
          <span class="text-brand">telematica</span><br />
          & voertuig&shy;installaties
        </h1>
        
        <!-- Subtext -->
        <p class="text-xl md:text-2xl text-gray-400 max-w-xl animate-fade-in-up delay-200" style="opacity: 0;">
          Vakkundige installatie van ritregistratie, dashcams en meer. Voor particulier én zakelijk.
        </p>
        
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-8 animate-fade-in-up delay-300" style="opacity: 0;">
          <a 
            href="/scharloo-install-site/contact/" 
            class="group bg-brand text-white px-8 py-4 text-lg font-semibold hover:bg-white hover:text-black transition-all duration-300 inline-flex items-center justify-center gap-3"
          >
            Offerte aanvragen
            <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
          </a>
          <a 
            href="/scharloo-install-site/diensten/" 
            class="border-2 border-white text-white px-8 py-4 text-lg font-semibold hover:bg-white hover:text-black transition-all duration-300 text-center"
          >
            Bekijk diensten
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Marquee ticker - MrBoost style -->
  <section class="bg-brand text-white py-4 overflow-hidden">
    <div class="animate-marquee whitespace-nowrap flex">
      {[...Array(2)].map(() => (
        <div class="flex items-center">
          {projects.map(project => (
            <span class="mx-8 text-lg font-medium flex items-center gap-4">
              <span class="text-white/60">{project.category}</span>
              <span class="w-2 h-2 bg-white rounded-full"></span>
              <span>{project.title}</span>
            </span>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- Services Grid - Dark -->
  <section class="py-32 bg-gray-950">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Section header -->
      <div class="mb-20 reveal">
        <p class="text-brand font-medium tracking-widest uppercase mb-4">Diensten</p>
        <h2 class="heading-lg">
          Wat wij<br />
          <span class="text-gray-500">voor u doen</span>
        </h2>
      </div>
      
      <!-- Services list -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border-t border-gray-800 reveal">
        {services.map((service, i) => (
          <a 
            href={`/scharloo-install-site/diensten/#${service.id}`}
            class={`group py-8 md:py-12 border-b border-gray-800 flex items-center justify-between hover:bg-gray-900 transition-colors px-4 md:px-8 ${i % 2 === 0 ? 'md:border-r' : ''}`}
          >
            <span class="text-2xl md:text-3xl font-bold group-hover:text-brand transition-colors">
              {service.title}
            </span>
            <span class="text-3xl text-gray-600 group-hover:text-brand group-hover:translate-x-2 transition-all duration-300">
              →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats - Big numbers -->
  <section class="py-24 bg-black">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8 text-center reveal">
        <div class="space-y-2">
          <p class="text-6xl md:text-7xl lg:text-8xl font-black text-brand">500+</p>
          <p class="text-gray-500 text-lg uppercase tracking-widest">Installaties</p>
        </div>
        <div class="space-y-2">
          <p class="text-6xl md:text-7xl lg:text-8xl font-black text-brand">15+</p>
          <p class="text-gray-500 text-lg uppercase tracking-widest">Jaar ervaring</p>
        </div>
        <div class="space-y-2">
          <p class="text-6xl md:text-7xl lg:text-8xl font-black text-brand">100%</p>
          <p class="text-gray-500 text-lg uppercase tracking-widest">Vakmanschap</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About teaser - Dark -->
  <section class="py-32 bg-gray-950">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <p class="text-brand font-medium tracking-widest uppercase mb-4">Over ons</p>
          <h2 class="heading-lg mb-8">
            Precisie &<br />
            <span class="text-gray-500">vakmanschap</span>
          </h2>
          <p class="text-xl text-gray-400 mb-8 leading-relaxed">
            Wij zijn gespecialiseerd in de professionele inbouw van voertuigelektronica. 
            Elke installatie wordt netjes en onzichtbaar weggewerkt, zonder losse kabels.
          </p>
          <a 
            href="/scharloo-install-site/over-ons/" 
            class="inline-flex items-center gap-3 text-lg font-semibold hover:text-brand transition-colors"
          >
            Meer over ons
            <span>→</span>
          </a>
        </div>
        <div class="reveal photo-card photo-card-accent">
          <img 
            src="/scharloo-install-site/images/team.jpg" 
            alt="Het Scharloo-Install team" 
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section - Brand -->
  <section class="py-32 bg-brand text-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center reveal">
      <h2 class="heading-lg mb-8">
        Klaar om te<br />beginnen?
      </h2>
      <p class="text-xl text-white/80 mb-12 max-w-xl mx-auto">
        Neem contact op voor een vrijblijvende offerte
      </p>
      <a 
        href="/scharloo-install-site/contact/" 
        class="group inline-flex items-center gap-3 bg-white text-brand px-10 py-5 text-xl font-bold hover:bg-black hover:text-white transition-all duration-300"
      >
        Neem contact op
        <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
      </a>
    </div>
  </section>
</Layout>

<script>
  // Scroll reveal animation
  const reveals = document.querySelectorAll('.reveal');
  
  const revealOnScroll = () => {
    reveals.forEach(el => {
      const top = el.getBoundingClientRect().top;
      const windowHeight = window.innerHeight;
      
      if (top < windowHeight - 100) {
        el.classList.add('active');
      }
    });
  };
  
  window.addEventListener('scroll', revealOnScroll);
  revealOnScroll(); // Initial check
</script>
