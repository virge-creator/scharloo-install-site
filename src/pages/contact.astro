---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Neem contact op met Scharloo-Install voor een vrijblijvende offerte.">
  <!-- Hero -->
  <section class="bg-black text-white py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <p class="text-brand font-medium mb-4 tracking-wide uppercase">Contact</p>
      <h1 class="text-5xl md:text-6xl font-bold mb-6">Neem contact op</h1>
      <p class="text-xl text-gray-300 max-w-2xl">
        Heeft u vragen of wilt u een offerte aanvragen? Wij helpen u graag verder.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Contact Form -->
        <div>
          <h2 class="text-3xl font-bold text-black mb-8">Stuur een bericht</h2>
          <form class="space-y-6" name="contact" method="POST" data-netlify="true">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Naam *</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required
                  class="w-full px-4 py-3 border border-gray-300 focus:border-brand focus:outline-none transition-colors"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Telefoon</label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone"
                  class="w-full px-4 py-3 border border-gray-300 focus:border-brand focus:outline-none transition-colors"
                />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">E-mail *</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3 border border-gray-300 focus:border-brand focus:outline-none transition-colors"
              />
            </div>
            <div>
              <label for="service" class="block text-sm font-medium text-gray-700 mb-2">Dienst</label>
              <select 
                id="service" 
                name="service"
                class="w-full px-4 py-3 border border-gray-300 focus:border-brand focus:outline-none transition-colors bg-white"
              >
                <option value="">Selecteer een dienst</option>
                <option value="ritregistratie">Ritregistratie</option>
                <option value="dashcam">Dashcam inbouw</option>
                <option value="canbus">CAN Bus installatie</option>
                <option value="driverid">Driver ID / RFID</option>
                <option value="tachograaf">Tachograaf</option>
                <option value="startblokkering">Startblokkering</option>
                <option value="io">I/O installatie</option>
                <option value="anders">Anders</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Bericht *</label>
              <textarea 
                id="message" 
                name="message" 
                rows="5" 
                required
                class="w-full px-4 py-3 border border-gray-300 focus:border-brand focus:outline-none transition-colors resize-none"
              ></textarea>
            </div>
            <button 
              type="submit"
              class="w-full bg-brand text-white px-8 py-4 text-lg font-medium hover:bg-brand-dark transition-colors"
            >
              Verstuur bericht
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="text-3xl font-bold text-black mb-8">Contact gegevens</h2>
          
          <div class="space-y-8">
            <div>
              <h3 class="font-semibold text-black mb-2">E-mail</h3>
              <a href="mailto:info@scharloo-install.nl" class="text-brand hover:underline text-lg">
                info@scharloo-install.nl
              </a>
            </div>
            
            <div>
              <h3 class="font-semibold text-black mb-2">Telefoon</h3>
              <a href="tel:+31612345678" class="text-brand hover:underline text-lg">
                +31 6 12 34 56 78
              </a>
            </div>
            
            <div>
              <h3 class="font-semibold text-black mb-2">Adres</h3>
              <p class="text-gray-600 text-lg">
                [Adres]<br />
                [Postcode] [Plaats]
              </p>
            </div>

            <div>
              <h3 class="font-semibold text-black mb-2">Openingstijden</h3>
              <p class="text-gray-600">
                Maandag - Vrijdag: 08:00 - 17:00<br />
                Zaterdag: Op afspraak<br />
                Zondag: Gesloten
              </p>
            </div>
          </div>

          <!-- Map placeholder -->
          <div class="mt-12 bg-gray-100 aspect-video flex items-center justify-center">
            <p class="text-gray-400">Kaart komt hier</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
