---
const navItems = [
  { href: '/diensten/', label: 'Diensten' },
  { href: '/samenwerken/', label: 'Samenwerken' },
  { href: '/blog/', label: 'Blog' },
  { 
    href: '/over-ons/', 
    label: 'Over ons',
    children: [
      { href: '/over-ons/', label: 'Over Scharloo-Install' },
      { href: '/team/', label: 'Ons Team' },
    ]
  },
  { href: '/contact/', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-black/90 backdrop-blur-sm border-b border-gray-800">
  <nav class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="hover:opacity-80 transition-opacity">
        <img 
          src="/images/logo-scharloo.png" 
          alt="Scharloo-Install" 
          class="h-14 md:h-16 w-auto -mb-2 -mt-[2px]"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-12">
        {navItems.map(item => (
          item.children ? (
            <div class="relative group">
              <a 
                href={item.href}
                class={`text-sm font-medium tracking-wide uppercase transition-colors inline-flex items-center gap-1.5 ${
                  currentPath.includes(item.href.split('/')[1]) || currentPath.includes('team')
                    ? 'text-brand border-b-2 border-brand pb-1' 
                    : 'text-gray-400 hover:text-brand'
                }`}
              >
                {item.label}
                <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              
              {/* Dropdown */}
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-gray-900 border border-gray-800 shadow-2xl shadow-black/50 min-w-[220px] py-2">
                  {/* Arrow */}
                  <div class="absolute -top-[6px] left-1/2 -translate-x-1/2 w-3 h-3 bg-gray-900 border-l border-t border-gray-800 rotate-45"></div>
                  
                  {item.children.map(child => (
                    <a 
                      href={child.href}
                      class={`block px-5 py-3 text-sm font-medium tracking-wide transition-all hover:bg-gray-800 hover:text-brand hover:pl-7 ${
                        currentPath === child.href 
                          ? 'text-brand bg-gray-800/50' 
                          : 'text-gray-400'
                      }`}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a 
              href={item.href}
              class={`text-sm font-medium tracking-wide uppercase transition-colors ${
                currentPath.includes(item.href.split('/')[1]) 
                  ? 'text-brand border-b-2 border-brand pb-1' 
                  : 'text-gray-400 hover:text-brand'
              }`}
            >
              {item.label}
            </a>
          )
        ))}
      </div>

      <!-- Mobile menu button -->
      <button 
        id="mobile-menu-btn"
        class="md:hidden p-2 text-white"
        aria-label="Menu openen"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Navigation Overlay -->
<div id="mobile-menu" class="fixed inset-0 bg-black z-[60] hidden flex-col justify-center items-center">
  <button 
    id="mobile-menu-close"
    class="absolute top-6 right-6 p-2 text-white"
    aria-label="Menu sluiten"
  >
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  
  <nav class="flex flex-col items-center space-y-6">
    <a href="/" class="text-4xl font-bold text-white hover:text-brand transition-colors">Home</a>
    {navItems.map(item => (
      item.children ? (
        <div class="flex flex-col items-center space-y-3">
          <a 
            href={item.href}
            class="text-4xl font-bold text-white hover:text-brand transition-colors"
          >
            {item.label}
          </a>
          {/* Mobile sub-items */}
          <div class="flex flex-col items-center space-y-2">
            {item.children.map(child => (
              <a 
                href={child.href}
                class="text-lg text-gray-500 hover:text-brand transition-colors"
              >
                {child.label}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a 
          href={item.href}
          class="text-4xl font-bold text-white hover:text-brand transition-colors"
        >
          {item.label}
        </a>
      )
    ))}
  </nav>
</div>

<!-- Spacer for fixed header -->
<div class="h-20"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('mobile-menu-close');
  
  btn?.addEventListener('click', () => {
    menu?.classList.remove('hidden');
    menu?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  });
  
  closeBtn?.addEventListener('click', () => {
    menu?.classList.add('hidden');
    menu?.classList.remove('flex');
    document.body.style.overflow = '';
  });
  
  // Close on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      menu?.classList.remove('flex');
      document.body.style.overflow = '';
    });
  });
</script>
