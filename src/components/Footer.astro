---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-950 text-white border-t border-gray-800">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-32 dots-corner-br">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Left: Big CTA text -->
      <div>
        <p class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
          Laten we<br />
          <span class="text-brand">samenwerken</span>
        </p>
      </div>
      
      <!-- Right: Contact info -->
      <div class="lg:text-right space-y-8">
        <div>
          <p class="text-gray-500 uppercase tracking-widest text-sm mb-2">Telefoon</p>
          <a href="tel:+31182796197" class="text-2xl font-semibold hover:text-brand transition-colors">
            0182 796 197
          </a>
        </div>
        <div>
          <p class="text-gray-500 uppercase tracking-widest text-sm mb-2">Email</p>
          <a href="mailto:info@scharloo-install.nl" class="text-2xl font-semibold hover:text-brand transition-colors">
            info@scharloo-install.nl
          </a>
        </div>
        <div>
          <a 
            href="/scharloo-install-site/contact/" 
            class="inline-flex items-center gap-3 bg-brand text-white px-8 py-4 text-lg font-semibold hover:bg-white hover:text-black transition-all duration-300 mt-4"
          >
            Contact opnemen
            <span>→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Bottom bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-sm">
        © {currentYear} Scharloo-Install — Uw inbouwpartner
      </p>
      <div class="flex items-center gap-8">
        <a href="/scharloo-install-site/privacy/" class="text-gray-500 text-sm hover:text-white transition-colors">Privacy</a>
        <a href="/scharloo-install-site/voorwaarden/" class="text-gray-500 text-sm hover:text-white transition-colors">Voorwaarden</a>
      </div>
    </div>
  </div>
</footer>
