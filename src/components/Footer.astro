---
const currentYear = new Date().getFullYear();
---

<footer class="bg-black text-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center space-x-2 mb-4">
          <span class="text-2xl font-bold text-white">Scharloo</span>
          <span class="text-2xl font-bold text-brand">Install</span>
        </div>
        <p class="text-gray-400 mb-6 max-w-md">
          Uw inbouwpartner voor professionele voertuigelektronica. 
          Van ritregistratie tot dashcams, wij zorgen voor vakkundige installatie.
        </p>
        <p class="text-brand font-semibold text-lg">Uw inbouwpartner</p>
      </div>

      <!-- Diensten -->
      <div>
        <h3 class="font-semibold text-white mb-4">Diensten</h3>
        <ul class="space-y-3 text-gray-400">
          <li><a href="/diensten#ritregistratie" class="hover:text-brand transition-colors">Ritregistratie</a></li>
          <li><a href="/diensten#dashcams" class="hover:text-brand transition-colors">Dashcams</a></li>
          <li><a href="/diensten#canbus" class="hover:text-brand transition-colors">CAN Bus</a></li>
          <li><a href="/diensten#tachograaf" class="hover:text-brand transition-colors">Tachografen</a></li>
          <li><a href="/diensten#startblokkering" class="hover:text-brand transition-colors">Startblokkeringen</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-semibold text-white mb-4">Contact</h3>
        <ul class="space-y-3 text-gray-400">
          <li>
            <a href="mailto:info@scharloo-install.nl" class="hover:text-brand transition-colors">
              info@scharloo-install.nl
            </a>
          </li>
          <li>
            <a href="tel:+31612345678" class="hover:text-brand transition-colors">
              +31 6 12 34 56 78
            </a>
          </li>
          <li class="pt-4">
            <a 
              href="/contact" 
              class="inline-block border border-brand text-brand px-6 py-2 hover:bg-brand hover:text-white transition-colors"
            >
              Contact opnemen
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-gray-500 text-sm">
        © {currentYear} Scharloo-Install. Alle rechten voorbehouden.
      </p>
      <div class="flex space-x-6 mt-4 md:mt-0">
        <a href="/privacy" class="text-gray-500 text-sm hover:text-brand transition-colors">Privacy</a>
        <a href="/voorwaarden" class="text-gray-500 text-sm hover:text-brand transition-colors">Voorwaarden</a>
      </div>
    </div>
  </div>
</footer>
